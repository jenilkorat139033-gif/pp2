#include<stdio.h>

int binary(int a[],int low,int high,int key){
int mid;

if(low<=high){
mid=(low+high)/2;

if(a[mid]==key)
return mid;

if(a[mid]>key)
return binary(a,low,mid-1,key);
else
return binary(a,mid+1,high,key);
}
return -1;
}

int main(){
int a[50],n,i,key,pos;

scanf("%d",&n);

for(i=0;i<n;i++)
scanf("%d",&a[i]);

scanf("%d",&key);

pos=binary(a,0,n-1,key);

if(pos==-1)
printf("Not found");
else
printf("Found");
}