#include<stdio.h>

void quick(int a[],int l,int h){
int i=l,j=h,pivot=a[l],temp;

while(i<j){
while(a[i]<=pivot) i++;
while(a[j]>pivot) j--;

if(i<j){
temp=a[i];
a[i]=a[j];
a[j]=temp;
}
}

temp=a[l];
a[l]=a[j];
a[j]=temp;

if(l<j-1) quick(a,l,j-1);
if(j+1<h) quick(a,j+1,h);
}

int main(){
int a[50],n,i;

scanf("%d",&n);

for(i=0;i<n;i++)
scanf("%d",&a[i]);

quick(a,0,n-1);

for(i=0;i<n;i++)
printf("%d ",a[i]);
}