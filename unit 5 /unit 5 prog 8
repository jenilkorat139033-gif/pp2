#include<stdio.h>

void merge(int a[],int l,int m,int h){
int i=l,j=m+1,k=l,b[50];

while(i<=m && j<=h){
if(a[i]<a[j]) b[k++]=a[i++];
else b[k++]=a[j++];
}

while(i<=m) b[k++]=a[i++];
while(j<=h) b[k++]=a[j++];

for(i=l;i<=h;i++)
a[i]=b[i];
}

void mergesort(int a[],int l,int h){
int m;

if(l<h){
m=(l+h)/2;
mergesort(a,l,m);
mergesort(a,m+1,h);
merge(a,l,m,h);
}
}

int main(){
int a[50],n,i;

scanf("%d",&n);

for(i=0;i<n;i++)
scanf("%d",&a[i]);

mergesort(a,0,n-1);

for(i=0;i<n;i++)
printf("%d ",a[i]);
}