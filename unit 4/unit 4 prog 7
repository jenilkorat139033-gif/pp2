#include<stdio.h>
struct emp{
int code;
char name[20];
float salary;
};

int main(){
struct emp e[5];
float max=0;
int i,pos=0;

for(i=0;i<5;i++){
scanf("%d %s %f",&e[i].code,e[i].name,&e[i].salary);
if(e[i].salary>max){
max=e[i].salary;
pos=i;
}
}

printf("Highest salary employee: %s",e[pos].name);
}